{
  "env": { "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1" },
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash",
      "Edit(/**)",
      "Write(/**)",
      "WebSearch"
    ],
    "ask": [
      "Bash(sudo *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(dd *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(mkfs*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)"
    ],
    "additionalDirectories": []
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "codeload.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    },
    "filesystem": {
      "denyRead": [
        "~/.ssh", "~/.aws", "~/.config/gcloud", "~/.gnupg", "~/.kube",
        "~/.npmrc", "~/.config/gh", "~/.netrc", "~/.git-credentials", "~/.docker"
      ],
      "denyWrite": ["./.git/hooks"]
    }
  },
  "enabledPlugins": { "skill-creator@claude-plugins-official": true }
}
